# Admin API Authentication Token
# Used to authenticate requests to /v1/admin/* endpoints
ADMIN_API_TOKEN=dev-admin-token

# Next.js Admin UI Client Configuration
# Public token injected into browser requests to cloud service
NEXT_PUBLIC_ADMIN_TOKEN=dev-admin-token

# Cloud Service API URL
# Used by admin UI to make requests to the cloud service
NEXT_PUBLIC_API_URL=http://localhost:8000
